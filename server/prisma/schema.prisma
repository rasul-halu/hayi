generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  firstName    String
  lastName     String?
  username     String?
  avatarUrl    String?
  languageCode String?
  isPremium    Boolean  @default(false)
  role          String   @default("USER")
  xp                       Int       @default(0)
  hearts                   Int       @default(5)
  maxHearts                Int       @default(5)
  streak                   Int       @default(0)
  longestStreak            Int       @default(0)
  totalCorrectAnswers      Int       @default(0)
  totalWrongAnswers        Int       @default(0)
  lastHeartRefillAt        DateTime  @default(now())
  lastLessonCompletedDate  DateTime?

  lessonProgress LessonProgress[]
  xpEvents XpEvent[]
  achievements UserAchievement[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([xp])
}

model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  attempts       Int       @default(0)
  correctAnswers Int       @default(0)
  wrongAnswers   Int       @default(0)
  completedAt    DateTime?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    String
  lessonId  String?
  uniqueKey String?  @unique
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  achievementKey String
  unlockedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

model Course {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  language    String
  isPublished Boolean   @default(false)
  order       Int       @default(0)

  chapters    Chapter[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Chapter {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, order])
  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  legacyId    String?  @unique
  chapterId   String
  title       String
  description String?
  order       Int
  xpReward    Int      @default(10)
  isPublished Boolean  @default(false)
  imageUrl    String?

  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions   Question[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([chapterId, order])
  @@index([chapterId])
}

model Question {
  id             String   @id @default(cuid())
  lessonId       String
  type           String
  order          Int
  prompt         String?
  translation    String?
  correctAnswer  String?
  audioUrl       String?
  characterImage String?
  explanation    String?

  options        Json?
  pairs          Json?
  words          Json?
  newWords       Json?
  metadata       Json?

  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([lessonId, order])
  @@index([lessonId])
}

model DictionaryWord {
  id             String   @id @default(cuid())
  lezgian        String
  russian        String
  transcription  String?
  exampleLezgian String?
  exampleRussian String?
  audioUrl       String?
  imageUrl       String?
  category       String?
  order          Int      @default(0)
  isPublished    Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isPublished])
  @@index([category, order])
}
